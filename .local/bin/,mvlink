#!/bin/sh
# ,mvlink — `mv SRC DEST && ln -s DEST SRC`, done safely: checks everything
# before moving, refuses non-atomic cross-filesystem moves (-C to allow), and
# leaves an absolute link target (-r for relative).  Details: -h.
set -eu

prog=${0##*/}

usage() {
    cat >&2 <<EOF
Usage: $prog [-f] [-v] [-r] [-p] [-C] SRC DEST
       $prog [-f] [-v] [-r] [-p] [-C] SRC... DIR

Moves each SRC to the destination, then creates a symlink at the old SRC
location pointing to the new file.

  -f  force: overwrite an existing destination / replace SRC
  -v  verbose: pass -v to mv and ln
  -r  relative symlink target instead of absolute, so the link survives
      moving SRC and DEST together (needs GNU ln / coreutils)
  -p  create missing destination directories (like mkdir -p)
  -C  allow a cross-filesystem move (non-atomic: a failure partway can leave
      DEST half-copied; if that happens, finish up with rsync -av and rm)

All sources are checked before the first move, so a refusal changes nothing.
EOF
}

# Filesystem device id of PATH, or of its nearest existing ancestor (so it also
# works for a not-yet-created destination).  Tries GNU stat, then BSD stat.
fsdev() {
    _p=$1
    while [ ! -e "$_p" ]; do
        case $_p in
            */*) _p=${_p%/*}; [ -n "$_p" ] || _p=/ ;;
            *)   _p=. ;;
        esac
    done
    stat -c '%d' "$_p" 2>/dev/null || stat -f '%d' "$_p"
}

# Set $target for a SRC: DEST itself, or DEST/basename(SRC) when moving into
# a directory.
set_target() {
    if [ -n "$dest_is_dir" ]; then
        target=${dest%/}/${1##*/}
    else
        target=$dest
    fi
}

force=
verbose=
relative=
createdirs=
crossfs_ok=

# Unknown flags are refused rather than forwarded to mv: flags like -n/-i/-u
# can make mv quietly skip the move, after which the ln step would replace a
# still-unmoved SRC with a symlink and lose it.
while [ $# -gt 0 ]; do
    case $1 in
        -h | --help) usage; exit 0 ;;
        -f | --force) force=1; shift ;;
        -v | --verbose) verbose=1; shift ;;
        -r | --relative) relative=1; shift ;;
        -p | --parents) createdirs=1; shift ;;
        -C | --cross-fs) crossfs_ok=1; shift ;;
        --) shift; break ;;
        -?*) echo "$prog: unknown option '$1' (see -h)" >&2; exit 1 ;;
        *) break ;;
    esac
done

if [ $# -lt 2 ]; then
    usage
    exit 1
fi

# Computing link targets needs realpath(1) — POSIX only since 2024 and absent
# from older stock macOS.  Without this gate it would fail between mv and ln,
# leaving a moved file with no symlink.
command -v realpath >/dev/null || {
    echo "$prog: 'realpath' not found on PATH; install coreutils (or use a newer macOS)." >&2
    exit 3
}

# BSD/macOS ln can't compute relative link targets; -r needs GNU ln.
if [ -n "$relative" ]; then
    case $(ln --version 2>/dev/null || true) in
        *coreutils*) ;;
        *)
            echo "$prog: -r needs GNU ln (coreutils); the active 'ln' can't make relative links." >&2
            echo "$prog: install coreutils, or omit -r for an absolute link." >&2
            exit 3
            ;;
    esac
fi

# The last operand is the destination; everything before it is a source.
for dest do :; done
nsrc=$(($# - 1))

# A directory dest: exists as one, written with a trailing '/', or implied by
# -p with multiple sources.
dest_is_dir=
if [ -d "$dest" ]; then
    dest_is_dir=1
else
    case $dest in */) dest_is_dir=1 ;; esac
    if [ -n "$createdirs" ] && [ "$nsrc" -gt 1 ]; then
        dest_is_dir=1
    fi
fi

if [ "$nsrc" -gt 1 ] && [ -z "$dest_is_dir" ]; then
    echo "$prog: target '$dest' is not a directory (required for multiple sources)" >&2
    exit 1
fi

# First pass: validate every SRC before anything is moved or created.
i=1
while [ "$i" -le "$nsrc" ]; do
    eval "src=\${$i}"
    i=$((i + 1))
    # A trailing slash on SRC (tab completion adds them to dirs) would make
    # the ln step fail after the move; strip it here and in the second pass.
    while [ "${src%/}" != "$src" ]; do src=${src%/}; done

    if [ ! -e "$src" ] && [ ! -L "$src" ]; then
        echo "$prog: '$src' does not exist" >&2
        exit 1
    fi

    set_target "$src"
    if [ -z "$force" ] && { [ -e "$target" ] || [ -L "$target" ]; }; then
        echo "$prog: '$target' already exists (use -f to overwrite)" >&2
        exit 2
    fi

    # Only a same-filesystem move is atomic (rename(2)); a cross-fs mv copies
    # then deletes, and can half-finish on any error.
    if [ -z "$crossfs_ok" ] && [ "$(fsdev "$src")" != "$(fsdev "$target")" ]; then
        echo "$prog: '$src' and '$target' are on different filesystems." >&2
        echo "$prog: a cross-filesystem move isn't atomic; a failure partway would" >&2
        echo "$prog: leave things half-moved.  Pass -C to allow it, or copy-then-symlink yourself." >&2
        exit 4
    fi
done

# -p dirs are created only after validation; a new dir is always on the same
# filesystem as its nearest existing ancestor, so the cross-fs answers hold.
if [ -n "$createdirs" ]; then
    if [ -n "$dest_is_dir" ]; then
        mkdir -p -- "$dest"
    else
        case $dest in
            */*) mkdir -p -- "${dest%/*}/" ;;
        esac
    fi
fi

# Second pass: move and link.
i=1
while [ "$i" -le "$nsrc" ]; do
    eval "src=\${$i}"
    i=$((i + 1))
    while [ "${src%/}" != "$src" ]; do src=${src%/}; done
    set_target "$src"

    # Re-check just before mv: catches two SRCs sharing a basename (each
    # validated against a target that didn't exist yet) and races since then.
    if [ -z "$force" ] && { [ -e "$target" ] || [ -L "$target" ]; }; then
        echo "$prog: '$target' already exists (use -f to overwrite)" >&2
        exit 2
    fi

    mv ${force:+"-f"} ${verbose:+"-v"} -- "$src" "$target"

    # Absolute link target: canonicalize the parent dir, keep the leaf as-is
    # (a moved symlink must be pointed at, not resolved through).
    tdir=$(realpath -- "$(dirname -- "$target")")
    target_abs="${tdir%/}/${target##*/}"

    lnopts=s
    [ -n "$relative" ] && lnopts="${lnopts}r"
    [ -n "$force" ] && lnopts="${lnopts}f"
    [ -n "$verbose" ] && lnopts="${lnopts}v"
    ln "-$lnopts" -- "$target_abs" "$src"
done
